generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(STUDENT)
  gradeLevel   String?
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  avatarColor  String   @default("#3B82F6")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  image            String?
  emailVerified    DateTime?
  onboardingCompleted Boolean @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts               Account[]

  sessions               LearningSession[]
  badges                 UserBadge[]
  examResults            ExamResult[]
  userStats              UserStats?
  createdQuestions       Question[]
  teacherAssignments     Assignment[]         @relation("TeacherAssignments")
  studentWritingSessions WritingSession[]   @relation("StudentWritingSessions")
  tasks                  Task[]
  taughtClasses          Class[]              @relation("TeacherClasses")
  joinedClasses          Class[]              @relation("StudentClasses")
  
  teacherCourses         Course[]             @relation("TeacherCourses")
  studentEnrollments     CourseEnrollment[]   @relation("StudentEnrollments")
  teacherLiveClasses     LiveClass[]          @relation("TeacherLiveClasses")
  liveClassAttendances   LiveClassAttendance[]
  userThreads            ForumThread[]        @relation("UserThreads")
  userReplies            ForumReply[]         @relation("UserReplies")
  certificates           Certificate[]
  dailyAttendances       DailyAttendance[]

  linkedChildren         ParentStudentLink[]  @relation("ParentLinks")
  linkedParents          ParentStudentLink[]  @relation("StudentLinks")
  notifications          Notification[]

  @@index([role])
  @@index([schoolId])
}

// ─────────────────────────────────────────
// CLASSES (Kelas)
// ─────────────────────────────────────────

model Class {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique // Kode 6 karakter untuk join (contoh: 8AX39B)
  description String?
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  teacherId   String
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  
  students    User[]   @relation("StudentClasses")
  exams       Exam[]
  assignments Assignment[]
  liveClasses LiveClass[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
}

// ─────────────────────────────────────────
// PERSONAL TASKS (Tugas Pribadi Siswa)
// ─────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  subject     String?
  deadline    DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Role {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  province  String
  npsn      String?  @unique
  users     User[]
  exams     Exam[]
  assignments Assignment[]
  classes   Class[]
  courses   Course[]
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// LEARNING SESSIONS & MESSAGES
// ─────────────────────────────────────────

model LearningSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  questionId   String?
  question     Question? @relation(fields: [questionId], references: [id])
  subject      String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  isCompleted  Boolean   @default(false)
  isCorrect    Boolean?
  hintsUsed    Int       @default(0)
  pointsEarned Int       @default(0)
  
  // Fitur Pengumpulan Jawaban
  finalAnswerText     String?
  finalAnswerImageUrl String?
  aiScore             Float?
  teacherScore        Float?
  aiFeedback          String?

  messages     Message[]
  stats        SessionStats?

  @@index([userId])
  @@index([questionId])
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  session   LearningSession @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String
  isHint    Boolean     @default(false)
  hintTier  Int?
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

enum MessageRole {
  USER
  ASSISTANT
}

model SessionStats {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         LearningSession @relation(fields: [sessionId], references: [id])
  durationSeconds Int
  thinkingTurns   Int
  firstAttemptAt  DateTime?
  solvedAt        DateTime?
  autonomyScore   Float
}

// ─────────────────────────────────────────
// QUESTIONS (Bank Soal Kurikulum Merdeka)
// ─────────────────────────────────────────

model Question {
  id                  String       @id @default(cuid())
  content             String
  type                QuestionType
  difficulty          Difficulty
  subject             String
  topic               String
  subtopic            String?
  gradeLevel          String
  phase               String
  capaianPembelajaran String?
  hintTier1           String
  hintTier2           String
  hintTier3           String
  correctAnswer       String?
  explanation         String
  tags                String       @default("[]")
  isPublic            Boolean      @default(true)
  isHots              Boolean      @default(false)  // Higher Order Thinking Skills
  isDailyGenerated    Boolean      @default(false)  // dibuat oleh AI cron harian
  createdById         String
  createdBy           User         @relation(fields: [createdById], references: [id])
  createdAt           DateTime     @default(now())
  sessions            LearningSession[]
  examQuestions       ExamQuestion[]

  @@index([subject, gradeLevel])
  @@index([topic])
  @@index([isDailyGenerated, createdAt])
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─────────────────────────────────────────
// GAMIFICATION
// ─────────────────────────────────────────

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserStats {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  totalPoints        Int      @default(0)
  totalSessions      Int      @default(0)
  totalCorrect       Int      @default(0)
  totalNoHintCorrect Int      @default(0)
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  autonomyIndex      Float    @default(0)
  aiCluster          String?
  predictedScore     Float?
  recommendedDiff    String?  @default("MEDIUM")
  lastActiveDate     DateTime?
  updatedAt          DateTime @updatedAt
}

// ─────────────────────────────────────────
// EXAM MODE
// ─────────────────────────────────────────

model Exam {
  id          String        @id @default(cuid())
  title       String
  schoolId    String
  school      School        @relation(fields: [schoolId], references: [id])
  createdById String
  targetGrade String
  durationMins Int
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean       @default(false)
  questions   ExamQuestion[]
  results     ExamResult[]
  classId     String?
  class       Class?        @relation(fields: [classId], references: [id])
  createdAt   DateTime      @default(now())

  @@index([schoolId, isActive])
}

model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int

  @@unique([examId, order])
}

model ExamResult {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  answers     String   @default("{}")
  score       Float?
  tabSwitches Int      @default(0)
  startedAt   DateTime
  submittedAt DateTime?

  @@unique([examId, userId])
}

// ─────────────────────────────────────────
// ASSIGNMENT SYSTEM (Backend v2)
// ─────────────────────────────────────────

model Assignment {
  id              String          @id @default(cuid())
  title           String
  instructions    String
  assignmentType  AssignmentType  @default(ESSAY)
  attachmentUrls  String          @default("[]")
  targetGrade     String?
  schoolId        String
  school          School          @relation(fields: [schoolId], references: [id])
  createdById     String
  createdBy       User            @relation("TeacherAssignments", fields: [createdById], references: [id])
  deadline        DateTime
  maxDurationMins Int
  minWordCount    Int?
  allowAttachment Boolean         @default(true)
  isPublished     Boolean         @default(false)
  classId         String?
  class           Class?          @relation(fields: [classId], references: [id])
  writingSessions WritingSession[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([schoolId])
  @@index([createdById])
  @@index([deadline])
}

enum AssignmentType {
  ESSAY
  GENERAL
}

// ─────────────────────────────────────────
// WRITING SESSION (Backend v2)
// ─────────────────────────────────────────

model WritingSession {
  id            String               @id @default(cuid())
  assignmentId  String
  assignment    Assignment           @relation(fields: [assignmentId], references: [id])
  studentId     String
  student       User                 @relation("StudentWritingSessions", fields: [studentId], references: [id])
  status        WritingSessionStatus @default(IN_PROGRESS)
  startedAt     DateTime             @default(now())
  submittedAt   DateTime?
  autoSubmitted Boolean              @default(false)
  finalContent      String?
  submissionContent String?
  submissionFileUrls String  @default("[]")
  wordCount         Int?
  aiRecommendedScore Float?
  aiScoreReasoning   String?
  teacherFinalScore  Float?
  teacherComment     String?
  gradedAt           DateTime?
  reminderSentStatus Int       @default(0) // 0: none, 1: H-3 sent, 2: H-1 sent
  events        WritingEvent[]
  analysisReport WritingAnalysisReport?
  pasteAttempts PasteAttempt[]

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
}

enum WritingSessionStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
  ABANDONED
}

model WritingEvent {
  id               Int              @id @default(autoincrement())
  writingSessionId String
  writingSession   WritingSession   @relation(fields: [writingSessionId], references: [id])
  sequenceNumber   Int
  absoluteTimestamp BigInt
  deltaFromPrevious Int
  eventType        WritingEventType
  characters       String?
  deleteCount      Int?
  cursorPosition   Int
  contentLength    Int
  contentSnapshot  String?

  @@index([writingSessionId, sequenceNumber])
}

enum WritingEventType {
  INSERT
  DELETE_BACK
  DELETE_FORWARD
  SELECT
  CURSOR_MOVE
  PASTE_BLOCKED
  FOCUS
  BLUR
}

model PasteAttempt {
  id               String         @id @default(cuid())
  writingSessionId String
  writingSession   WritingSession @relation(fields: [writingSessionId], references: [id])
  attemptedAt      DateTime       @default(now())
  source           String
  clipboardLength  Int

  @@index([writingSessionId])
}

model WritingAnalysisReport {
  id                String         @id @default(cuid())
  writingSessionId  String         @unique
  writingSession    WritingSession @relation(fields: [writingSessionId], references: [id])
  overallVerdict    String
  confidenceScore   Float
  flags             String         @default("[]")
  metrics           String         @default("{}")
  playbackFrames    String?
  reviewedByTeacher Boolean        @default(false)
  teacherNote       String?
  finalDecision     String?
  generatedAt       DateTime       @default(now())

  @@index([overallVerdict])
}

// ─────────────────────────────────────────
// DAILY QUESTION SETS (Soal Harian AI)
// ─────────────────────────────────────────

model DailyQuestionSet {
  id          String   @id @default(cuid())
  date        String   // Format: "2026-06-04" (tanggal soal berlaku)
  gradeLevel  String   // "Kelas 7", "Kelas 8", dst.
  subject     String   // "Matematika", "IPA", dst.
  questionIds String   @default("[]") // JSON array of Question IDs, urutan 1-5
  generatedAt DateTime @default(now())

  @@unique([date, gradeLevel, subject])
  @@index([date])
  @@index([gradeLevel])
  @@index([date, gradeLevel])
}

// ─────────────────────────────────────────
// PARENT-STUDENT LINK
// ─────────────────────────────────────────

model ParentStudentLink {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ParentLinks", fields: [parentId], references: [id])
  studentId String
  student   User     @relation("StudentLinks", fields: [studentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([parentId, studentId])
  @@index([parentId])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  href      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotificationType {
  STREAK_WARNING
  ASSIGNMENT_NEW
  ASSIGNMENT_GRADED
  EXAM_STARTING
  BADGE_EARNED
  SUBMISSION_RECEIVED
  DAILY_REMINDER
}

// ─────────────────────────────────────────
// NEXT-AUTH ACCOUNTS
// ─────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─────────────────────────────────────────
// COURSE MANAGEMENT
// ─────────────────────────────────────────
model Course {
  id              String           @id @default(cuid())
  title           String
  description     String?
  gradeLevel      String
  subject         String
  schoolId        String?
  school          School?          @relation(fields: [schoolId], references: [id])
  createdById     String
  createdBy       User             @relation("TeacherCourses", fields: [createdById], references: [id])
  isPublished     Boolean          @default(false)
  modules         CourseModule[]
  enrollments     CourseEnrollment[]
  forumThreads    ForumThread[]
  certificates    Certificate[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CourseModule {
  id              String           @id @default(cuid())
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title           String
  order           Int
  materials       CourseMaterial[]
  createdAt       DateTime         @default(now())
}

model CourseMaterial {
  id              String           @id @default(cuid())
  moduleId        String
  module          CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  type            MaterialType
  contentUrl      String?
  textContent     String?
  order           Int
  createdAt       DateTime         @default(now())
}

enum MaterialType {
  VIDEO
  PDF
  TEXT
}

model CourseEnrollment {
  id              String           @id @default(cuid())
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation("StudentEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  progressPct     Float            @default(0)
  completed       Boolean          @default(false)
  enrolledAt      DateTime         @default(now())

  @@unique([courseId, userId])
}

// ─────────────────────────────────────────
// LIVE CLASS
// ─────────────────────────────────────────
model LiveClass {
  id              String           @id @default(cuid())
  title           String
  description     String?
  scheduledAt     DateTime
  zoomUrl         String?
  classId         String?
  schoolClass     Class?           @relation(fields: [classId], references: [id])
  teacherId       String
  teacher         User             @relation("TeacherLiveClasses", fields: [teacherId], references: [id])
  attendances     LiveClassAttendance[]
  createdAt       DateTime         @default(now())
}

model LiveClassAttendance {
  id              String           @id @default(cuid())
  liveClassId     String
  liveClass       LiveClass        @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime         @default(now())
  durationMins    Int?

  @@unique([liveClassId, userId])
}

// ─────────────────────────────────────────
// DISCUSSION FORUM
// ─────────────────────────────────────────
model ForumThread {
  id              String           @id @default(cuid())
  title           String
  content         String
  courseId        String?
  course          Course?          @relation(fields: [courseId], references: [id])
  authorId        String
  author          User             @relation("UserThreads", fields: [authorId], references: [id])
  replies         ForumReply[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ForumReply {
  id              String           @id @default(cuid())
  threadId        String
  thread          ForumThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content         String
  authorId        String
  author          User             @relation("UserReplies", fields: [authorId], references: [id])
  upvotes         Int              @default(0)
  isBestAnswer    Boolean          @default(false)
  createdAt       DateTime         @default(now())
}

// ─────────────────────────────────────────
// CERTIFICATE & ATTENDANCE
// ─────────────────────────────────────────
model Certificate {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  courseId        String?
  course          Course?          @relation(fields: [courseId], references: [id])
  title           String
  qrCodeUrl       String?
  issuedAt        DateTime         @default(now())
}

model DailyAttendance {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  date            String
  status          String
  loginCount      Int              @default(1)
  totalDurationMs BigInt           @default(0)

  @@unique([userId, date])
}
